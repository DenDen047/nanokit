{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "1000000",
    "ECC_MCP_RECONNECT_ZOTERO": "bash ~/.claude/scripts/zotero-mcp-server.sh start",
    "ECC_MCP_RECONNECT_WORKSPACE_PERSONAL": "bash ~/.claude/scripts/workspace-mcp-personal-server.sh start",
    "ECC_MCP_RECONNECT_SCRAPLING": "bash ~/.claude/scripts/scrapling-mcp-server.sh start"
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(ps:*)",
      "Bash(wc:*)",
      "Bash(mmdc:*)",
      "Bash(gh api:*)",
      "Bash(gh search:*)",
      "Bash(git add:*)",
      "Bash(git commit -m:*)",
      "Bash(grep:*)",
      "Bash(pixi info:*)",
      "Bash(pixi install:*)",
      "Bash(pixi run:*)",
      "Bash(tmux:*)",
      "Bash(claude:*)",
      "Bash(mkdir:*)",
      "Bash(TZ=Asia/Tokyo date:*)",
      "Read(/tmp/*)",
      "Write(/tmp/*)",
      "Edit(/tmp/*)",
      "Bash(rm /tmp*)",
      "Read(**/.claude/settings.json)",
      "Read(**/.claude/settings.local.json)",
      "Edit(**/.claude/settings.json)",
      "Edit(**/.claude/settings.local.json)",
      "Write(**/.claude/settings.local.json)",
      "WebSearch",
      "WebFetch",
      "mcp__scrapling__get",
      "mcp__scrapling__bulk_get",
      "mcp__scrapling__fetch",
      "mcp__scrapling__bulk_fetch",
      "mcp__scrapling__stealthy_fetch",
      "mcp__scrapling__bulk_stealthy_fetch",
      "mcp__scrapling__open_session",
      "mcp__scrapling__close_session",
      "mcp__scrapling__list_sessions"
    ],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/zotero-mcp-server.sh start",
            "timeout": 20
          },
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/workspace-mcp-personal-server.sh start",
            "timeout": 20
          },
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/scrapling-mcp-server.sh start",
            "timeout": 20
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/karpathy-reminder.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/plot-vision-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bun x -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "warp@claude-code-warp": true
  },
  "extraKnownMarketplaces": {
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    }
  },
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "latest",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true,
  "editorMode": "vim",
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "skipWorkflowUsageWarning": true,
  "tui": "fullscreen"
}
