{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "1000000",
    "ECC_MCP_RECONNECT_ZOTERO": "bash ~/.claude/scripts/zotero-mcp-server.sh start",
    "ECC_MCP_RECONNECT_WORKSPACE_PERSONAL": "bash ~/.claude/scripts/workspace-mcp-personal-server.sh start"
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(ps:*)",
      "Bash(wc:*)",
      "Bash(mmdc:*)",
      "Bash(gh api:*)",
      "Bash(gh search:*)",
      "Bash(git add:*)",
      "Bash(git commit -m:*)",
      "Bash(grep:*)",
      "Bash(pixi info:*)",
      "Bash(pixi install:*)",
      "Bash(pixi run:*)",
      "Bash(tmux:*)",
      "Bash(claude:*)",
      "Bash(mkdir:*)",
      "Bash(TZ=Asia/Tokyo date:*)",
      "Bash(~/Documents/Projects/claude-settings/.claude/skills/morning-routine/scripts/launch-task-pane.sh:*)",
      "Bash(~/Documents/Projects/claude-settings/.claude/skills/morning-routine/scripts/teardown-session.sh:*)",
      "Read(/tmp/*)",
      "Write(/tmp/*)",
      "Edit(/tmp/*)",
      "Bash(rm /tmp*)",
      "Read(**/.claude/settings.json)",
      "Read(**/.claude/settings.local.json)",
      "Edit(**/.claude/settings.json)",
      "Edit(**/.claude/settings.local.json)",
      "Write(**/.claude/settings.local.json)",
      "WebSearch",
      "WebFetch",
      "mcp__scrapling__get",
      "mcp__scrapling__bulk_get",
      "mcp__scrapling__fetch",
      "mcp__scrapling__bulk_fetch",
      "mcp__scrapling__stealthy_fetch",
      "mcp__scrapling__bulk_stealthy_fetch",
      "mcp__scrapling__open_session",
      "mcp__scrapling__close_session",
      "mcp__scrapling__list_sessions"
    ],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/zotero-mcp-server.sh start",
            "timeout": 20
          },
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/workspace-mcp-personal-server.sh start",
            "timeout": 20
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bun x -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {},
  "extraKnownMarketplaces": {},
  "autoUpdatesChannel": "latest",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true,
  "voiceEnabled": true,
  "skipAutoPermissionPrompt": true
}
