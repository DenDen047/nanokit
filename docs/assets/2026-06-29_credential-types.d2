direction: down

vars: {
  d2-config: {
    theme-id: 200
    dark-theme-id: 200
  }
}

classes: {
  new: {
    style: {
      fill: "#16a34a"
      stroke: "#14532d"
      stroke-width: 2
      font-color: "#ffffff"
      font-size: 18
      bold: true
    }
  }
  base: {
    style: {
      fill: "#475569"
      stroke: "#1e293b"
      stroke-width: 1
      font-color: "#ffffff"
      font-size: 18
      bold: true
    }
  }
  attn: {
    style: {
      fill: "#d97706"
      stroke: "#7c2d12"
      stroke-width: 2
      font-color: "#ffffff"
      font-size: 18
      bold: true
    }
  }
  bad: {
    style: {
      fill: "#b91c1c"
      stroke: "#7f1d1d"
      stroke-width: 2
      font-color: "#ffffff"
      font-size: 18
      bold: true
    }
  }
}

typeA: "タイプA: ポータブルなトークン / OAuth creds" {
  direction: down
  who: "個人 Google ・ HDT Google ・ frogiraffe Slack/Notion" {
    class: base
  }
  prop: "秘密の実体が Keychain / creds dir に手元にある\nどのMCPサーバ・どのプロセスからでも使える\nClaude のログインに依存しない" {
    class: base
  }
  res: "→ 並列に置ける (どのフォルダからでも到達可)" {
    class: new
  }
  who -> prop -> res
}

typeB: "タイプB: Team Connector (claude.ai 連携)" {
  direction: down
  who2: "HDT Slack ・ HDT Notion" {
    class: base
  }
  prop2: "HDT Team アカウントに紐づく\n~/.claude-hdt でログインした時だけ有効\nポータブルな秘密が手元に無い (会社が中央管理)" {
    class: base
  }
  res2: "→ そのままでは並列に置けない\ncross-org-search 子 (direnv exec HDT claude -p) 経由でのみ読める" {
    class: attn
  }
  who2 -> prop2 -> res2
}

key: "だから差が出る: HDT Google は タイプA なので :8324 で並列化できる。\nHDT Slack/Notion だけ タイプB なので別扱いになっている。" {
  class: new
}

choice: "全部並列にしたいなら → HDT Slack/Notion も タイプA 化\n(= HDT の Slack xoxp トークン / Notion インテグレーションを自分で発行)\n会社ポリシーが許せば可能。ただし企業秘密がローカルに増える" {
  class: bad
}

typeA -> key
typeB -> key
key -> choice: "条件付きで一様化できる"
